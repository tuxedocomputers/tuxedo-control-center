{
  "name": "tuxedo-control-center",
  "description": "TUXEDO Control Center Application",
  "version": "2.1.20",
  "main": "./dist/tuxedo-control-center/e-app/e-app/main.js",
  "author": {
    "name": "TUXEDO Computers GmbH",
    "email": "tux@tuxedocomputers.com",
    "url": "https://tuxedocomputers.com"
  },
  "license": "GPL-3.0",
  "homepage": "https://tuxedocomputers.com",
  "scripts": {
    "postinstall": "npm run && electron-builder install-app-deps",
    "ver": "sh build-src/inc-version.sh",
    "inc-version-patch": "npm version patch --no-git-tag-version && cd src && npm version patch --no-git-tag-version",
    "inc-version-minor": "npm version minor --no-git-tag-version && cd src && npm version minor --no-git-tag-version",
    "inc-version-major": "npm version major --no-git-tag-version && cd src && npm version major --no-git-tag-version",
    "start": "electron ./dist/tuxedo-control-center",
    "start-tccd-debug": "sudo node --enable-source-maps ./dist/tuxedo-control-center/service-app/service-app/main.js --start",
    "build": "run-s clean build-electron build-native build-service build-ng copy-files",
    "build-prod": "run-s clean build-electron build-native build-service build-ng-prod copy-files",
    "build-ng": "npm run copy-changelog && ng build",
    "build-ng-prod": "npm run copy-changelog && ng build --configuration production --aot true --optimization true",
    "build-electron": "tsc -p ./src/e-app",
    "build-service": "tsc -p ./src/service-app && cp ./src/package.json ./dist/tuxedo-control-center/service-app/package.json && run-s bundle-service",
    "bundle-service": "mkdir -p ./dist/tuxedo-control-center/data/service && run-s esbuild-service && pkg --compress=Brotli --target node24-linux-x64 --output ./dist/tuxedo-control-center/data/service/tccd ./dist/tuxedo-control-center/service-app/package.json",
    "build-native": "node-gyp configure && node-gyp rebuild",
    "esbuild-service": "cp ./build/Release/TuxedoIOAPI.node ./dist/tuxedo-control-center/service-app/native-lib/ && esbuild ./dist/tuxedo-control-center/service-app/service-app/main.js --tree-shaking=true --bundle --minify --drop:debugger --define:DEBUG=false --platform=node --loader:.node=copy --asset-names=[name] --outfile=./dist/tuxedo-control-center/service-app/service-app/esbuild.js",
    "copy-files": "run-s copy-package-json copy-dist-files copy-cameractls copy-udev-rule",
    "copy-package-json": "cp ./src/package.json ./dist/tuxedo-control-center/package.json",
    "copy-dist-files": "cp -r ./src/dist-data ./dist/tuxedo-control-center/data && mkdir -p ./usr/share/metainfo && cp ./src/dist-data/com.tuxedocomputers.tcc.metainfo.xml ./usr/share/metainfo",
    "copy-changelog": "cp CHANGELOG.md ./src/ng-app/assets/",
    "copy-cameractls": "mkdir -p ./dist/tuxedo-control-center/data/camera && cp ./src/cameractrls/cameractrls.py ./src/cameractrls/v4l2_kernel_names.json ./dist/tuxedo-control-center/data/camera",
    "copy-udev-rule": "cp ./src/udev/99-webcam.rules ./dist/tuxedo-control-center/data/dist-data",
    "electron-builder": "tsx ./build-src/electron-builder.ts",
    "pack": "run-s build && npm run electron-builder",
    "build-release": "tsx ./build-src/build-release.ts",
    "check-release": "tsx ./build-src/check-release.ts",
    "pack-prod": "run-s build-prod && npm run electron-builder",
    "clean": "rm -rf ./dist; rm -rf ./build; rm -rf ./usr",
    "tests": "npm run test-common && npm run test-service-app && npm run test-appstream",
    "test-common": "tsx node_modules/jasmine/bin/jasmine --config=./src/common/jasmine.json",
    "test-service-app": "tsx node_modules/jasmine/bin/jasmine --config=./src/service-app/jasmine.json",
    "test-ng": "ng test --watch=false",
    "test-ng-e2e": "ng e2e",
    "test-appstream": "appstreamcli validate ./src/dist-data/com.tuxedocomputers.tcc.metainfo.xml",
    "install-build-dep": "curl -sL https://deb.nodesource.com/setup_24.x | sudo -E bash - && sudo apt install nodejs autoconf automake build-essential gcc g++ make rpm",
    "start-watch": "run-s clean build-electron build-native build-service copy-files && npm run watch-ng-and-electron",
    "watch-ng-and-electron": "run-p start-ng-watch start-electron-watch",
    "start-ng-watch": "ng build --watch",
    "start-electron-watch": "electron ./dist/tuxedo-control-center --watch",
    "gen-lang": "ng extract-i18n --output-path src/ng-app/assets/locale/ --out-file lang.xlf",
    "gen-lang-all": "run-s gen-lang && xliff-simple-merge -i 'src/ng-app/assets/locale/lang.xlf' -d 'src/ng-app/assets/locale/lang.en.xlf' -o 'src/ng-app/assets/locale/lang.en.xlf' && xliff-simple-merge -i 'src/ng-app/assets/locale/lang.xlf' -d 'src/ng-app/assets/locale/lang.de.xlf' -o 'src/ng-app/assets/locale/lang.de.xlf'",
    "ng-update": "ng update",
    "deb-compression": "cd ./dist/packages/ && dpkg-deb -R $npm_config_deb_path deb-data && dpkg-deb -Z=xz -z=9 -S=extreme -b deb-data $npm_config_deb_path"
  },
  "private": true,
  "dependencies": {
    "@angular/compiler": "20.3.7",
    "@angular/core": "20.3.7",
    "@angular/forms": "20.3.7",
    "@angular/localize": "20.3.7",
    "@angular/platform-browser": "20.3.7",
    "@angular/platform-browser-dynamic": "20.3.7",
    "@angular/router": "20.3.7",
    "assert": "2.1.0",
    "async-mutex": "0.5.0",
    "chart.js": "4.5.1",
    "chartjs-plugin-datalabels": "2.2.0",
    "chartjs-plugin-dragdata": "2.3.1",
    "dbus-next": "git+https://github.com/tuxedoxt/node-dbus-next.git#e875f304780e0d8108dbe1d7e7bdcf6ba9e9313f",
    "ng2-charts": "8.0.0",
    "ngx-color-picker": "17.0.0",
    "ngx-markdown": "20.1.0",
    "node-ble": "git+https://github.com/tuxedoxt/node-ble.git#match-and-event-leak-fixes-v2",
    "node-gyp": "11.5.0",
    "process": "0.11.10",
    "rxjs": "7.8.2",
    "stream": "0.0.3",
    "usocket": "git+https://github.com/tuxedoder/usocket.git#3ae051d98c7d5cc3e74c8cdbc8e6f3dc3bf60ac6",
    "util": "0.12.5",
    "x11": "2.3.0",
    "xliff": "6.2.2",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.7",
    "@angular/animations": "20.3.7",
    "@angular/cdk": "20.2.10",
    "@angular/cli": "20.3.7",
    "@angular/compiler-cli": "20.3.7",
    "@angular/language-service": "20.3.7",
    "@angular/material": "20.2.10",
    "@types/jasmine": "5.1.12",
    "@types/jasminewd2": "2.0.13",
    "@types/node": "24.9.1",
    "@yao-pkg/pkg": "6.9.0",
    "angular-gauge": "5.0.0",
    "electron": "38.4.0",
    "electron-builder": "26.0.20",
    "electron-reload": "1.5.0",
    "esbuild": "0.25.11",
    "jasmine": "5.12.0",
    "jasmine-core": "5.12.0",
    "jasmine-spec-reporter": "7.0.0",
    "karma": "6.4.4",
    "karma-jasmine": "5.1.0",
    "mock-fs": "5.5.0",
    "node-addon-api": "8.5.0",
    "npm-run-all": "4.1.5",
    "tsx": "4.20.6",
    "xliff-simple-merge": "1.3.0"
  },
  "overrides": {
    "dbus-next": {
      "xml2js": "0.6.2"
    }
  },
  "browser": {
    "child_process": false,
    "crypto": false,
    "fs": false,
    "net": false,
    "os": false,
    "path": false,
    "timers": false,
    "x11": false
  }
}
